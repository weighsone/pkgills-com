---
import Layout from '../../layouts/Layout.astro';
import { u } from '../../utils/url';
---

<Layout title="Lakes, Ponds & Golf Course RFP" description="Request a quote or proposal for lake, pond, and golf course aquatic management services from P.K. Gills Aquatics in Arizona.">

  <section class="py-16 relative" style="background: linear-gradient(135deg, #041e35, #063356);">
    <div class="absolute inset-0 overflow-hidden">
      <img src={u("/images/Header-Contact-scene.jpg")} alt="" class="w-full h-full object-cover opacity-20" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm mb-6" style="color: #6ec2f7;">
        <a href={u("/")} style="color: #a8dbfb;" class="hover:text-white">Home</a>
        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={u("/contact")} style="color: #a8dbfb;" class="hover:text-white">Contact</a>
        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span>Lakes, Ponds & Golf</span>
      </nav>
      <h1 class="font-display font-bold text-white text-4xl md:text-5xl mb-4">Lakes, Ponds & Golf Course RFP</h1>
      <p class="text-xl max-w-2xl" style="color: #a8dbfb;">Request a proposal for fish stocking or aquatic management services for your lake, pond, or golf course water feature.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-gray-100 shadow-sm p-8">
        <form action="mailto:patannchurch@pkgills.com" method="post" enctype="text/plain" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="name">Your Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="Your full name" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="org">Organization / Property</label>
              <input type="text" id="org" name="organization" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="HOA, Golf Club, etc." />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="email">Email</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="you@example.com" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="(480) 555-0100" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="location">Water Body Location</label>
            <input type="text" id="location" name="location" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="City, neighborhood, or address" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="type">Water Body Type</label>
              <select id="type" name="waterBodyType" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none bg-white">
                <option value="">Select type...</option>
                <option>Private Lake</option>
                <option>HOA Community Lake</option>
                <option>Golf Course Pond</option>
                <option>Retention Basin</option>
                <option>Decorative Pond</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="size">Approximate Size</label>
              <input type="text" id="size" name="size" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="e.g., 3 acres, 50,000 sq ft" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Services Needed</label>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {['Fish Stocking', 'Water Quality Management', 'Vegetation Control', 'Aeration', 'Fish Harvesting', 'Ongoing Management Program'].map(service => (
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="services" value={service} class="rounded border-gray-300" />
                  <span class="text-sm text-gray-700">{service}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="details">Additional Details</label>
            <textarea id="details" name="details" rows="4" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none resize-none" placeholder="Current fish population, water quality issues, goals, timeline, budget considerations..."></textarea>
          </div>

          <button type="submit" class="w-full px-6 py-3 rounded-xl font-semibold text-white" style="background-color: #0d6aae;">
            Submit RFP
          </button>
        </form>
      </div>
    </div>
  </section>

</Layout>
