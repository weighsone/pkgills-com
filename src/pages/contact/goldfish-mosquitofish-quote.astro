---
import Layout from '../../layouts/Layout.astro';
import { u } from '../../utils/url';
---

<Layout title="Goldfish & Mosquitofish Quote" description="Request a quote for Goldfish or Mosquitofish (Gambusia) for decorative ponds or mosquito control in Arizona.">

  <section class="py-16 relative" style="background: linear-gradient(135deg, #041e35, #063356);">
    <div class="absolute inset-0 overflow-hidden">
      <img src={u("/images/Header-Contact-scene.jpg")} alt="" class="w-full h-full object-cover opacity-20" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm mb-6" style="color: #6ec2f7;">
        <a href={u("/")} style="color: #a8dbfb;" class="hover:text-white">Home</a>
        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={u("/contact")} style="color: #a8dbfb;" class="hover:text-white">Contact</a>
        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span>Goldfish & Mosquitofish Quote</span>
      </nav>
      <h1 class="font-display font-bold text-white text-4xl md:text-5xl mb-4">Goldfish & Mosquitofish Quote</h1>
      <p class="text-xl max-w-2xl" style="color: #a8dbfb;">Get a quote for decorative Goldfish or Gambusia mosquitofish for your pond or water feature.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Info cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
        <div class="rounded-xl p-5 border border-gray-100 shadow-sm">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-3" style="background-color: #fef3c7;">
            <svg class="w-5 h-5" style="color: #d97706;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="font-semibold text-sm mb-1" style="color: #041e35;">Decorative Goldfish</h3>
          <p class="text-xs text-gray-500">Beautiful, colorful fish for ornamental ponds and water gardens. Hardy in Arizona's climate.</p>
        </div>
        <div class="rounded-xl p-5 border border-gray-100 shadow-sm">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-3" style="background-color: #fee2e2;">
            <svg class="w-5 h-5" style="color: #dc2626;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </div>
          <h3 class="font-semibold text-sm mb-1" style="color: #041e35;">Gambusia (Mosquitofish)</h3>
          <p class="text-xs text-gray-500">Natural mosquito larvae control. Widely used by health departments and irrigation districts.</p>
        </div>
      </div>

      <div class="rounded-2xl border border-gray-100 shadow-sm p-8">
        <form action="https://formspree.io/f/mrerklqv" method="post" class="space-y-5">
              <input type="hidden" name="_subject" value="Goldfish & Mosquitofish Quote — PK Gills Website" />
              <input type="hidden" name="_next" value="https://dev.pkgills.com/contact/goldfish-mosquitofish-quote" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="name">Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="Your name" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="(480) 555-0100" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="email">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="you@example.com" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Fish Type Needed</label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="fishType" value="goldfish" class="rounded border-gray-300" />
                <span class="text-sm text-gray-700">Goldfish</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="fishType" value="gambusia" class="rounded border-gray-300" />
                <span class="text-sm text-gray-700">Gambusia (Mosquitofish)</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="fishType" value="both" class="rounded border-gray-300" />
                <span class="text-sm text-gray-700">Both</span>
              </label>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="quantity">Approximate Quantity Needed</label>
            <input type="text" id="quantity" name="quantity" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="e.g., 50 goldfish, 200 gambusia" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="location">Water Body Location</label>
            <input type="text" id="location" name="location" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none" placeholder="City or address in Arizona" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="details">Details</label>
            <textarea id="details" name="details" rows="4" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none resize-none" placeholder="Pond size, purpose (decorative vs. mosquito control), current conditions, timeline..."></textarea>
          </div>

          <button type="submit" class="w-full px-6 py-3 rounded-xl font-semibold text-white" style="background-color: #0d6aae;">
            Request Quote
          </button>
        </form>
      </div>
    </div>
  </section>

</Layout>
