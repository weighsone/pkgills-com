---
import Layout from '../../layouts/Layout.astro';
import { u } from '../../utils/url';
---

<Layout title="Contact Us" description="Contact P.K. Gills Aquatics for live fish supply and aquatic management services in Arizona. Call (480) 456-0744 or email PatAnnChurch@pkgills.com.">

  <section class="py-16 relative" style="background: linear-gradient(135deg, #041e35, #063356);">
    <div class="absolute inset-0 overflow-hidden">
      <img src={u("/images/Header-Contact-scene.jpg")} alt="" class="w-full h-full object-cover opacity-20" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm mb-6" style="color: #6ec2f7;">
        <a href={u("/")} style="color: #a8dbfb;" class="hover:text-white">Home</a>
        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span>Contact Us</span>
      </nav>
      <h1 class="font-display font-bold text-white text-4xl md:text-5xl mb-4">Contact Us</h1>
      <p class="text-xl max-w-2xl" style="color: #a8dbfb;">Ready to discuss your aquatic management needs? Reach out to Pat directly.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Contact Info -->
        <div class="lg:col-span-1 space-y-6">
          <div>
            <h2 class="font-display font-bold text-xl mb-4" style="color: #041e35;">Get in Touch</h2>
            <div class="space-y-4">
              <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-100 shadow-sm">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: #d6effd;">
                  <svg class="w-5 h-5" style="color: #0d6aae;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <div class="text-xs text-gray-500 uppercase tracking-wide font-medium mb-1">Phone</div>
                  <a href="tel:4804560744" class="font-semibold" style="color: #0d6aae;">(480) 456-0744</a>
                </div>
              </div>

              <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-100 shadow-sm">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: #d6effd;">
                  <svg class="w-5 h-5" style="color: #0d6aae;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <div class="text-xs text-gray-500 uppercase tracking-wide font-medium mb-1">Email</div>
                  <a href="mailto:PatAnnChurch@pkgills.com" class="font-semibold break-all" style="color: #0d6aae;">PatAnnChurch@pkgills.com</a>
                </div>
              </div>

              <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-100 shadow-sm">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: #d6effd;">
                  <svg class="w-5 h-5" style="color: #0d6aae;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <div class="text-xs text-gray-500 uppercase tracking-wide font-medium mb-1">Address</div>
                  <address class="not-italic font-medium text-gray-700 text-sm">
                    261 N. Roosevelt Ave.<br/>
                    Chandler, AZ 85226
                  </address>
                </div>
              </div>
            </div>
          </div>

          <!-- Specialized RFP Links -->
          <div class="rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
            <div class="px-4 py-3 font-semibold text-white text-sm" style="background-color: #041e35;">Specialized Request Forms</div>
            <div class="divide-y divide-gray-100">
              <a href={u("/contact/lakes-ponds-golf")} class="flex items-center justify-between p-4 hover:bg-gray-50 transition-colors group">
                <div>
                  <div class="text-sm font-medium text-gray-800 group-hover:text-blue-700">Lakes, Ponds & Golf RFP</div>
                  <div class="text-xs text-gray-500">Golf courses, HOAs, private lakes</div>
                </div>
                <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
              <a href={u("/contact/goldfish-mosquitofish-quote")} class="flex items-center justify-between p-4 hover:bg-gray-50 transition-colors group">
                <div>
                  <div class="text-sm font-medium text-gray-800 group-hover:text-blue-700">Goldfish & Mosquitofish Quote</div>
                  <div class="text-xs text-gray-500">Decorative ponds & mosquito control</div>
                </div>
                <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
              <a href={u("/contact/irrigation-districts")} class="flex items-center justify-between p-4 hover:bg-gray-50 transition-colors group">
                <div>
                  <div class="text-sm font-medium text-gray-800 group-hover:text-blue-700">Irrigation Districts RFP</div>
                  <div class="text-xs text-gray-500">Canals, reservoirs, municipal water</div>
                </div>
                <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- General Contact Form -->
        <div class="lg:col-span-2">
          <div class="rounded-2xl border border-gray-100 shadow-sm p-8">
            <h2 class="font-display font-bold text-2xl mb-2" style="color: #041e35;">Send Us a Message</h2>
            <p class="text-gray-500 text-sm mb-6">For a faster response, call us at <a href="tel:4804560744" style="color: #0d6aae;">(480) 456-0744</a> or use one of the specialized forms for quotes.</p>

            <form action="https://api.web3forms.com/submit" method="post" class="space-y-5">
              <input type="hidden" name="access_key" value="29d173aa-d4a8-4a8a-af28-8cbeeed87f68" />
              <input type="hidden" name="subject" value="General Enquiry — PK Gills Website" />
              <input type="hidden" name="redirect" value="https://dev.pkgills.com/contact/thank-you" />
              <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5" for="firstName">First Name</label>
                  <input type="text" id="firstName" name="firstName" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:border-transparent" style="focus-ring-color: #0d6aae;" placeholder="Pat" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5" for="lastName">Last Name</label>
                  <input type="text" id="lastName" name="lastName" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:border-transparent" placeholder="Smith" />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="email">Email Address</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:border-transparent" placeholder="you@example.com" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="phone">Phone Number</label>
                <input type="tel" id="phone" name="phone" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:border-transparent" placeholder="(480) 555-0100" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="subject">Subject</label>
                <select id="subject" name="subject" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:border-transparent bg-white">
                  <option value="">Select a topic...</option>
                  <option value="live-fish">Live Fish Order</option>
                  <option value="lake-management">Lake/Pond Management</option>
                  <option value="golf-course">Golf Course Services</option>
                  <option value="irrigation">Irrigation District Services</option>
                  <option value="mosquito">Mosquito Control</option>
                  <option value="decorative">Decorative Pond / Koi</option>
                  <option value="general">General Inquiry</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="message">Message</label>
                <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:border-transparent resize-none" placeholder="Tell us about your water body, what species you're interested in, and any relevant details about your project..."></textarea>
              </div>

              <button type="submit" class="w-full px-6 py-3 rounded-xl font-semibold text-white transition-colors" style="background-color: #0d6aae;">
                Send Message
              </button>
              <p class="text-xs text-gray-400 text-center">We typically respond within 1 business day.</p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
