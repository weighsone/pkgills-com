---
import Layout from '../layouts/Layout.astro';
import { u } from '../utils/url';
---

<Layout title="About Us" description="Pat Church has been in the aquatic industry since 1974. Learn about P.K. Gills Aquatics and Fresh Catch Fish's history and mission.">

  <!-- Page Hero -->
  <section class="py-16 relative" style="background: linear-gradient(135deg, #041e35, #063356);">
    <div class="absolute inset-0 overflow-hidden">
      <img src={u("/images/Header-About-scene.jpg")} alt="" class="w-full h-full object-cover opacity-20" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm mb-6" style="color: #6ec2f7;">
        <a href={u("/")} style="color: #a8dbfb;" class="hover:text-white">Home</a>
        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span>About Us</span>
      </nav>
      <h1 class="font-display font-bold text-white text-4xl md:text-5xl">About P.K. Gills Aquatics</h1>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <div class="rounded-2xl overflow-hidden shadow-md sticky top-24">
            <div class="p-8 text-white text-center" style="background: linear-gradient(135deg, #041e35, #094e84);">
              <div class="w-24 h-24 rounded-full mx-auto mb-4 flex items-center justify-center text-2xl font-display font-bold" style="background: rgba(255,255,255,0.15);">PAC</div>
              <h2 class="font-display font-bold text-xl mb-1">Pat Church</h2>
              <p class="text-sm opacity-75">Owner & Founder</p>
              <p class="text-sm opacity-75 mt-1">P.K. Gills Aquatics / FCF</p>
            </div>
            <div class="bg-white p-6 space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 flex-shrink-0" style="color: #0d6aae;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <div>
                  <div class="text-xs text-gray-500 uppercase tracking-wide font-medium">Location</div>
                  <div class="text-sm text-gray-700">261 N. Roosevelt Ave.<br/>Chandler, AZ 85226</div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 flex-shrink-0" style="color: #0d6aae;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <div>
                  <div class="text-xs text-gray-500 uppercase tracking-wide font-medium">Phone</div>
                  <a href="tel:4804560744" class="text-sm" style="color: #0d6aae;">(480) 456-0744</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 flex-shrink-0" style="color: #0d6aae;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <div>
                  <div class="text-xs text-gray-500 uppercase tracking-wide font-medium">Email</div>
                  <a href="mailto:PatAnnChurch@pkgills.com" class="text-sm break-all" style="color: #0d6aae;">PatAnnChurch@pkgills.com</a>
                </div>
              </div>
              <div class="pt-2">
                <a href={u("/contact")} class="block w-full text-center px-4 py-3 rounded-lg font-semibold text-white text-sm" style="background-color: #0d6aae;">Contact Pat</a>
              </div>
            </div>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-8">
          <div class="prose prose-lg max-w-none">
            <h2 class="font-display font-bold text-2xl mb-4" style="color: #041e35;">A Legacy in Aquatics</h2>
            <p class="text-gray-600 leading-relaxed">
              P.K. Gills Aquatics is owned and operated by Pat Church, a recognized expert in the aquatic industry with a career spanning more than five decades. Pat's involvement in aquatics began in 1974, giving her unmatched depth of knowledge in live fish supply, water management, and ecosystem health.
            </p>
            <p class="text-gray-600 leading-relaxed">
              After successfully growing and selling her previous aquatic services company, ADI, in 1998, Pat channeled her expertise into a new venture. In 1999, she established both Fresh Catch Fish (FCF) and P.K. Gills Aquatics — creating a vertically integrated operation that handles everything from fish sourcing and transport to full lake management programs.
            </p>
          </div>

          <div class="rounded-2xl p-6" style="background-color: #eef8ff; border: 1px solid #d6effd;">
            <h3 class="font-display font-bold text-xl mb-4" style="color: #041e35;">What Sets Us Apart</h3>
            <ul class="space-y-3">
              {[
                'Over 30 years of direct owner experience — not just management oversight',
                'A division of Fresh Catch Fish (FCF), giving us direct sourcing capability',
                'Arizona-based and operated — we know local water conditions and regulations',
                'Competitive pricing backed by efficient logistics and established supply chains',
                'Personal service from Pat herself on every account',
                'Track record with irrigation districts, golf courses, HOAs, and private lakes'
              ].map(item => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 mt-0.5 flex-shrink-0" style="color: #0d6aae;" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-gray-700 text-sm">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="font-display font-bold text-xl mb-4" style="color: #041e35;">Who We Serve</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { title: 'Lakes & Ponds', desc: 'Private and community lakes requiring stocking, management, and water quality programs.' },
                { title: 'Golf Courses', desc: 'Course water features and ponds that benefit from fish stocking and management services.' },
                { title: 'Irrigation Districts', desc: 'Municipal and agricultural irrigation canals and reservoirs across Arizona.' },
                { title: 'HOAs', desc: 'Homeowner associations managing community lakes and retention basins.' },
                { title: 'Decorative Features', desc: 'Residential and commercial water gardens and koi ponds requiring quality fish.' },
                { title: 'Public Recreation', desc: 'Public fishing derbies, stocking programs, and community aquatics initiatives.' }
              ].map(client => (
                <div class="rounded-xl p-4 border border-gray-100 shadow-sm">
                  <h4 class="font-semibold text-sm mb-1" style="color: #041e35;">{client.title}</h4>
                  <p class="text-xs text-gray-500">{client.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="rounded-2xl p-6 border-l-4" style="background-color: #f0fdf4; border-color: #059669;">
            <p class="text-gray-700 italic leading-relaxed">"Our mission is simple — deliver healthy fish on time, at fair prices, with the expertise to help you maintain a thriving aquatic environment. Pat's 50-year track record is our guarantee."</p>
            <p class="text-sm font-semibold mt-3" style="color: #041e35;">— P.K. Gills Aquatics</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
