---
import Layout from '../layouts/Layout.astro';
import { u } from '../utils/url';
---

<Layout title="Live Fish Supply & Aquatic Management" description="P.K. Gills Aquatics — Live fish supply and sustainable aquatic water management in Arizona. Over 30 years of experience serving lakes, ponds, golf courses, and irrigation districts.">

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #020e1a 0%, #041e35 40%, #063356 70%, #094e84 100%);">
    <!-- Hero background image with overlay -->
    <div class="absolute inset-0">
      <img src={u("/images/Header-Home-scene.jpg")} alt="" class="w-full h-full object-cover opacity-20" />
    </div>
    <div class="absolute inset-0 opacity-10">
      <div class="absolute rounded-full" style="width: 600px; height: 600px; top: -100px; right: -100px; border: 1px solid #38a6f0;"></div>
      <div class="absolute rounded-full" style="width: 400px; height: 400px; top: 50px; right: 50px; border: 1px solid #38a6f0;"></div>
      <div class="absolute rounded-full" style="width: 800px; height: 800px; bottom: -200px; left: -200px; border: 1px solid #1488d8;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-medium mb-6" style="background-color: rgba(20,136,216,0.2); color: #6ec2f7;">
          <span class="w-2 h-2 rounded-full" style="background-color: #34d399;"></span>
          Arizona's Trusted Aquatics Partner Since 1999
        </div>
        <h1 class="font-display font-bold text-white mb-6" style="font-size: clamp(2.25rem, 5vw, 3.5rem); line-height: 1.15;">
          Live Fish + Expertise<br/>
          <span style="color: #38a6f0;">+</span> Good Prices<br/>
          <span style="color: #6ec2f7;">= Better Water Quality</span>
        </h1>
        <p class="text-xl mb-8 max-w-2xl leading-relaxed" style="color: #a8dbfb;">
          P.K. Gills is a division of Arizona-based Fresh Catch Fish. We supply live fish and provide comprehensive aquatic water management services for lakes, ponds, golf courses, and irrigation districts across Arizona.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={u("/contact")} class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-white transition-all duration-200 shadow-lg" style="background: linear-gradient(135deg, #0d6aae, #094e84);">
            Request a Quote
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href={u("/species")} class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold transition-all duration-200" style="border: 2px solid rgba(56,166,240,0.5); color: #a8dbfb; background: rgba(13,106,174,0.15);">
            View Species Available
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full" style="height: 60px; display: block;">
        <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-10 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl font-display font-bold" style="color: #0d6aae;">30+</div>
          <div class="text-sm text-gray-500 mt-1">Years Experience</div>
        </div>
        <div>
          <div class="text-3xl font-display font-bold" style="color: #0d6aae;">14+</div>
          <div class="text-sm text-gray-500 mt-1">Species Available</div>
        </div>
        <div>
          <div class="text-3xl font-display font-bold" style="color: #0d6aae;">AZ</div>
          <div class="text-sm text-gray-500 mt-1">Based & Operated</div>
        </div>
        <div>
          <div class="text-3xl font-display font-bold" style="color: #0d6aae;">1974</div>
          <div class="text-sm text-gray-500 mt-1">Industry Since</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-4xl mb-4" style="color: #041e35;">Complete Aquatic Management Solutions</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">From live fish stocking to comprehensive water quality programs, we provide everything your water body needs to thrive.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #d6effd, #a8dbfb);">
            <svg class="w-6 h-6" style="color: #0d6aae;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl mb-2" style="color: #041e35;">Live Fish Stocking</h3>
          <p class="text-gray-600 text-sm leading-relaxed">We supply and deliver 14+ species of live fish — bass, bluegill, catfish, koi, trout, and more — direct to your water body.</p>
          <a href={u("/species")} class="inline-flex items-center mt-4 text-sm font-semibold" style="color: #0d6aae;">
            View species <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #d1fae5, #a7f3d0);">
            <svg class="w-6 h-6" style="color: #059669;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl mb-2" style="color: #041e35;">Lake & Pond Management</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Comprehensive management programs including aeration, chemical applications, mechanical harvesting, dye treatments, and food chain balancing.</p>
          <a href={u("/why-fish")} class="inline-flex items-center mt-4 text-sm font-semibold" style="color: #059669;">
            Learn more <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #fef3c7, #fde68a);">
            <svg class="w-6 h-6" style="color: #d97706;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl mb-2" style="color: #041e35;">Golf Courses & HOAs</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Specialized services for golf course water features and HOA lakes — improving aesthetics, water quality, and recreational fishing opportunities.</p>
          <a href={u("/contact/lakes-ponds-golf")} class="inline-flex items-center mt-4 text-sm font-semibold" style="color: #d97706;">
            Request RFP <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #ede9fe, #ddd6fe);">
            <svg class="w-6 h-6" style="color: #7c3aed;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl mb-2" style="color: #041e35;">Irrigation Districts</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Targeted fish stocking programs for irrigation canals and reservoirs — mosquito control, vegetation management, and ecosystem balance.</p>
          <a href={u("/contact/irrigation-districts")} class="inline-flex items-center mt-4 text-sm font-semibold" style="color: #7c3aed;">
            Request RFP <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #fee2e2, #fecaca);">
            <svg class="w-6 h-6" style="color: #dc2626;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl mb-2" style="color: #041e35;">Mosquito Control</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Natural mosquito control using Gambusia (mosquitofish) and Goldfish — a sustainable, chemical-free solution for standing water bodies.</p>
          <a href={u("/contact/goldfish-mosquitofish-quote")} class="inline-flex items-center mt-4 text-sm font-semibold" style="color: #dc2626;">
            Get a quote <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #e0f2fe, #bae6fd);">
            <svg class="w-6 h-6" style="color: #0284c7;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl mb-2" style="color: #041e35;">Decorative Ponds</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Beautiful Koi and Goldfish for decorative ponds and water gardens. We source healthy, vibrant fish to enhance your property.</p>
          <a href={u("/species")} class="inline-flex items-center mt-4 text-sm font-semibold" style="color: #0284c7;">
            View species <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="py-20" style="background-color: #eef8ff;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block px-3 py-1 rounded-full text-sm font-medium mb-4" style="background-color: #d6effd; color: #0d6aae;">Our Story</div>
          <h2 class="font-display font-bold text-4xl mb-6" style="color: #041e35;">30 Years of Aquatic Expertise</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            P.K. Gills is owned and operated by Pat Church, who has been in the aquatic industry since 1974. After selling her previous company ADI in 1998, she established Fresh Catch Fish (FCF) and P.K. Gills Aquatics in 1999.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Based in Chandler, Arizona, we serve lakes, ponds, golf courses, irrigation districts, and decorative water features throughout the state. Our owner's 30+ year track record means you get proven expertise with every delivery.
          </p>
          <a href={u("/about")} class="inline-flex items-center px-6 py-3 rounded-lg font-semibold text-white" style="background-color: #0d6aae;">
            Meet Pat Church
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-2xl overflow-hidden" style="aspect-ratio: 1;">
            <img src={u("/images/Tempe-Town-Lake-Fish-Truck.jpg")} alt="P.K. Gills delivery truck at Tempe Town Lake" class="w-full h-full object-cover" />
          </div>
          <div class="rounded-2xl overflow-hidden mt-6" style="aspect-ratio: 1;">
            <img src={u("/images/Tempe-Town-Lake-Fish-Pat.jpg")} alt="Pat Church at Tempe Town Lake fish delivery" class="w-full h-full object-cover" />
          </div>
          <div class="rounded-2xl overflow-hidden" style="aspect-ratio: 1;">
            <img src={u("/images/Dobson-Fishing-1.jpg")} alt="Dobson Ranch fishing derby" class="w-full h-full object-cover" />
          </div>
          <div class="rounded-2xl overflow-hidden mt-6" style="aspect-ratio: 1;">
            <img src={u("/images/patdel1.jpg")} alt="Pat Church fish delivery" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Teaser -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-4xl mb-4" style="color: #041e35;">Trusted by Professionals</h2>
        <p class="text-gray-600 max-w-xl mx-auto">From aquatics companies to water conservation districts, our clients trust us with their most important water resources.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="rounded-2xl p-6 border border-gray-100 shadow-sm">
          <p class="text-gray-600 text-sm leading-relaxed mb-4 italic">"PK Gills has been a tremendous asset. Pat is an expert in the field. Her knowledge and passion for aquatics is unmatched."</p>
          <div class="font-semibold text-sm" style="color: #041e35;">Janet Scheffman</div>
          <div class="text-xs text-gray-500">Hurricane Aquatics</div>
        </div>
        <div class="rounded-2xl p-6 border border-gray-100 shadow-sm">
          <p class="text-gray-600 text-sm leading-relaxed mb-4 italic">"Pat Church is wonderful to work with — punctual, dependable, and her prices are very competitive."</p>
          <div class="font-semibold text-sm" style="color: #041e35;">Lynn Cook, CPA</div>
          <div class="text-xs text-gray-500">Client</div>
        </div>
        <div class="rounded-2xl p-6 border border-gray-100 shadow-sm">
          <p class="text-gray-600 text-sm leading-relaxed mb-4 italic">"The Roosevelt Water Conservation District has relied on PK Gills for years. Pat's track record speaks for itself."</p>
          <div class="font-semibold text-sm" style="color: #041e35;">B. Strader, P.E.</div>
          <div class="text-xs text-gray-500">Roosevelt Water Conservation District</div>
        </div>
      </div>
      <div class="text-center mt-8">
        <a href={u("/testimonials")} class="inline-flex items-center gap-2 text-sm font-semibold" style="color: #0d6aae;">
          Read all testimonials <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20" style="background: linear-gradient(135deg, #041e35, #063356);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-bold text-white mb-4" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">Ready to Improve Your Water Quality?</h2>
      <p class="text-xl mb-8" style="color: #a8dbfb;">Contact us today for a free consultation and competitive quote on live fish or aquatic management services.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={u("/contact")} class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-white shadow-lg" style="background: linear-gradient(135deg, #0d6aae, #094e84);">
          Get a Free Quote
        </a>
        <a href="tel:4804560744" class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold" style="border: 2px solid rgba(168,219,251,0.4); color: #a8dbfb;">
          Call (480) 456-0744
        </a>
      </div>
    </div>
  </section>

</Layout>
