---
import Layout from '../layouts/Layout.astro';
import { u } from '../utils/url';

const resources = [
  {
    category: 'Fish',
    items: [
      { title: 'Bass Fishing in Arizona Reservoirs', desc: 'A guide to understanding Largemouth Bass behavior in Arizona\'s unique desert reservoir environment.', type: 'Article' },
      { title: 'Bluegill Management Guide', desc: 'Comprehensive guide to managing Bluegill populations for optimal predator-prey balance in managed lakes.', type: 'Guide' },
      { title: 'Rainbow Trout Stocking in Arizona', desc: 'Best practices for seasonal trout stocking in warm-climate states, including temperature thresholds and timing.', type: 'Article' },
      { title: 'Channel Catfish Pond Management', desc: 'Recommendations for catfish density, feeding programs, and harvest schedules in managed ponds.', type: 'Guide' },
    ]
  },
  {
    category: 'Algae & Water Quality',
    items: [
      { title: 'Controlling Blue-Green Algae', desc: 'Understanding cyanobacteria blooms and integrated management strategies for lakes and ponds.', type: 'Article' },
      { title: 'Water Quality Testing for Lake Managers', desc: 'Key parameters to monitor and what they mean for your fish population and water body health.', type: 'Guide' },
      { title: 'Aquatic Dye Applications', desc: 'How aquatic dye treatments work, their benefits, application rates, and safety considerations.', type: 'Article' },
    ]
  },
  {
    category: 'Aquatic Insects & Invertebrates',
    items: [
      { title: 'Aquatic Invertebrates as Fish Forage', desc: 'The role of invertebrates in the aquatic food chain and how they support fish growth.', type: 'Article' },
      { title: 'Mosquito Control in Water Bodies', desc: 'Integrated mosquito management using biological controls (Gambusia) and best management practices.', type: 'Guide' },
    ]
  },
  {
    category: 'Molluscs',
    items: [
      { title: 'Quagga Mussel Prevention', desc: 'Preventing invasive mussel introduction into Arizona water bodies — inspection and decontamination protocols.', type: 'Article' },
      { title: 'Snail Management with Redear Sunfish', desc: 'Using Redear Sunfish as biological control for aquatic snail populations.', type: 'Guide' },
    ]
  }
];
---

<Layout title="Articles & Links" description="Educational articles and resources on fish, algae, aquatic insects, and water management from P.K. Gills Aquatics.">

  <section class="py-16" style="background: linear-gradient(135deg, #041e35, #063356);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm mb-6" style="color: #6ec2f7;">
        <a href={u("/")} style="color: #a8dbfb;" class="hover:text-white">Home</a>
        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span>Articles & Links</span>
      </nav>
      <h1 class="font-display font-bold text-white text-4xl md:text-5xl mb-4">Articles & Links</h1>
      <p class="text-xl max-w-2xl" style="color: #a8dbfb;">Educational resources on aquatic management, fish, water quality, and more.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      {resources.map(section => (
        <div>
          <h2 class="font-display font-bold text-2xl mb-6" style="color: #041e35;">{section.category}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {section.items.map(item => (
              <div class="rounded-xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-shadow">
                <div class="flex items-start justify-between gap-3 mb-2">
                  <h3 class="font-semibold text-sm" style="color: #041e35;">{item.title}</h3>
                  <span class="text-xs px-2 py-0.5 rounded-full font-medium flex-shrink-0" style="background-color: #d6effd; color: #0d6aae;">{item.type}</span>
                </div>
                <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      ))}

      <div class="rounded-2xl p-8 text-center border border-gray-200">
        <h3 class="font-display font-bold text-xl mb-3" style="color: #041e35;">Have a Question Not Covered Here?</h3>
        <p class="text-gray-600 mb-5">Pat Ann's 50 years of experience means she's likely encountered your situation before. Reach out directly for expert advice.</p>
        <a href={u("/contact")} class="inline-flex items-center px-6 py-3 rounded-xl font-semibold text-white" style="background-color: #0d6aae;">Ask Pat</a>
      </div>
    </div>
  </section>

</Layout>
