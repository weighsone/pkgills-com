---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'P.K. Gills Aquatics — Live fish supply and sustainable aquatic water management in Chandler, Arizona.' } = Astro.props;

// BASE_URL = '/pkgills-com/' on GitHub Pages staging, '/' on custom domain
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // strip trailing slash
const u = (path: string) => `${base}${path}`; // e.g. u('/about') → '/pkgills-com/about'

const navLinks = [
  { href: u('/'), label: 'Home' },
  { href: u('/about'), label: 'About Us' },
  {
    href: u('/why-fish'),
    label: 'Why Fish?',
    children: [
      { href: u('/why-fish/stocking-fish'), label: 'Stocking Fish' },
      { href: u('/why-fish/transporting-fish'), label: 'Transporting Fish' },
      { href: u('/why-fish/fish-habitats'), label: 'Fish Habitats & Shelters' },
      { href: u('/why-fish/supplemental-feeding'), label: 'Supplemental Feeding' },
    ]
  },
  { href: u('/species'), label: 'Species Available' },
  { href: u('/articles'), label: 'Articles & Links' },
  { href: u('/testimonials'), label: 'Testimonials' },
  { href: u('/contact'), label: 'Contact Us' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title} | P.K. Gills Aquatics</title>
  </head>
  <body class="min-h-screen flex flex-col">

    <!-- Header -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">

          <!-- Logo -->
          <a href={u('/')} class="flex items-center group">
            <img src={u('/images/pkgills-logo.png')} alt="P.K. Gills Aquatics" class="h-12 md:h-14 w-auto" />
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden lg:flex items-center gap-1">
            {navLinks.map(link => (
              link.children ? (
                <div class="relative group">
                  <button class={`px-3 py-2 rounded-md text-sm font-medium transition-colors flex items-center gap-1 ${currentPath.startsWith(link.href) ? 'text-blue-700 bg-blue-50' : 'text-gray-700 hover:text-blue-700 hover:bg-gray-50'}`}>
                    {link.label}
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </button>
                  <div class="absolute top-full left-0 pt-1 hidden group-hover:block">
                    <div class="bg-white rounded-lg shadow-lg border border-gray-100 py-1 min-w-48">
                      <a href={link.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700">Overview</a>
                      {link.children.map(child => (
                        <a href={child.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700">{child.label}</a>
                      ))}
                    </div>
                  </div>
                </div>
              ) : (
                <a
                  href={link.href}
                  class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${currentPath === link.href ? 'text-blue-700 bg-blue-50' : 'text-gray-700 hover:text-blue-700 hover:bg-gray-50'}`}
                >
                  {link.label}
                </a>
              )
            ))}
          </nav>

          <!-- CTA -->
          <div class="hidden md:flex items-center gap-3">
            <a href="tel:4804560744" class="text-sm font-medium text-gray-600 hover:text-blue-700 transition-colors">
              (480) 456-0744
            </a>
            <a href={u('/contact')} class="px-4 py-2 rounded-lg text-sm font-semibold text-white transition-colors" style="background-color: #0d6aae;" onmouseover="this.style.backgroundColor='#094e84'" onmouseout="this.style.backgroundColor='#0d6aae'">
              Get a Quote
            </a>
          </div>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-100" aria-label="Toggle menu">
            <svg id="menu-open-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg id="menu-close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Nav -->
      <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
        <nav class="max-w-7xl mx-auto px-4 py-3 space-y-1">
          {navLinks.map(link => (
            <div>
              <a href={link.href} class={`block px-3 py-2 rounded-md text-sm font-medium ${currentPath === link.href || currentPath.startsWith(link.href + '/') ? 'text-blue-700 bg-blue-50' : 'text-gray-700 hover:bg-gray-50'}`}>
                {link.label}
              </a>
              {link.children && (
                <div class="ml-4 mt-1 space-y-1">
                  {link.children.map(child => (
                    <a href={child.href} class={`block px-3 py-1.5 rounded-md text-sm ${currentPath === child.href ? 'text-blue-700 bg-blue-50' : 'text-gray-600 hover:bg-gray-50'}`}>
                      {child.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
          <div class="pt-2 border-t border-gray-100">
            <a href="tel:4804560744" class="block px-3 py-2 text-sm font-medium text-gray-600">(480) 456-0744</a>
            <a href={u('/contact')} class="block mt-1 px-3 py-2 rounded-lg text-sm font-semibold text-white text-center" style="background-color: #0d6aae;">Get a Quote</a>
          </div>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="background-color: #041e35; color: #d1d5db;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
          <div>
            <div class="mb-3">
              <img src={u('/images/pkgills-logo.png')} alt="P.K. Gills Aquatics" class="h-12 w-auto brightness-0 invert opacity-90" />
            </div>
            <p class="text-sm leading-relaxed" style="color: #9ca3af;">A division of Fresh Catch Fish (FCF). Over 30 years of experience in live fish supply and sustainable aquatic water management.</p>
          </div>

          <div>
            <h3 class="font-semibold text-white mb-3">Quick Links</h3>
            <ul class="space-y-2">
              {navLinks.filter(l => !l.children).map(link => (
                <li><a href={link.href} class="text-sm transition-colors hover:text-white" style="color: #9ca3af;">{link.label}</a></li>
              ))}
              <li><a href={u('/why-fish')} class="text-sm transition-colors hover:text-white" style="color: #9ca3af;">Why Fish?</a></li>
            </ul>
          </div>

          <div>
            <h3 class="font-semibold text-white mb-3">Contact</h3>
            <address class="not-italic space-y-2 text-sm" style="color: #9ca3af;">
              <p>261 N. Roosevelt Ave.<br/>Chandler, AZ 85226</p>
              <p><a href="tel:4804560744" class="hover:text-white transition-colors">(480) 456-0744</a></p>
              <p><a href="mailto:PatAnnChurch@pkgills.com" class="hover:text-white transition-colors">PatAnnChurch@pkgills.com</a></p>
            </address>
          </div>
        </div>

        <div class="border-t pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-sm" style="border-color: #1e3a5f; color: #6b7280;">
          <p>&copy; {new Date().getFullYear()} P.K. Gills Aquatics / Fresh Catch Fish. All rights reserved.</p>
          <p>Chandler, Arizona</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const openIcon = document.getElementById('menu-open-icon');
      const closeIcon = document.getElementById('menu-close-icon');

      btn?.addEventListener('click', () => {
        const isHidden = menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', !isHidden);
        openIcon?.classList.toggle('hidden', !isHidden);
        closeIcon?.classList.toggle('hidden', isHidden);
      });
    </script>
  </body>
</html>
